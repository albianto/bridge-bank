# Bridge Bank configuration
# Copy this file to .env and fill in your values

# Lemon Squeezy licence key (received after purchase)
LICENCE_KEY=

# Enable Banking (from enablebanking.com)
# Your Application ID — matches the filename of your .pem key file
EB_APPLICATION_ID=

# Actual Budget
ACTUAL_URL=http://192.168.1.100:5006
ACTUAL_PASSWORD=
ACTUAL_SYNC_ID=
ACTUAL_ACCOUNT=

# Email notifications
NOTIFY_EMAIL=
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587

# Sync settings
SYNC_TIME=06:00
ACCOUNT_HOLDER_NAME=

# Flask secret key (generate any random string)
SECRET_KEY=change-me-to-something-random
